{
  "name": "nugget-nihongo",
  "version": "15.6.0",
  "description": "Hybrid PWA for learning Japanese — JLPT N5 to N1, targeting Indonesian speakers",
  "private": true,
  "license": "MIT",
  "author": "Nugget Nihongo <nugget.nihongo@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/nuggetenak/nugget-nihongo.git"
  },
  "homepage": "https://nuggetenak.github.io/nugget-nihongo/",
  "keywords": ["jlpt", "japanese", "language-learning", "pwa", "vanilla-js", "supabase", "cloudflare"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node tests/run.js",
    "validate": "node tests/run.js",
    "start": "npx http-server public -p 3000 -c-1",
    "serve": "npx http-server public -p 3000 -c-1 --push-state",
    "lint:data": "node -e \"require('./tests/run.js')\"",
    "check:version": "node -e \"const fs=require('fs');const v=fs.readFileSync('public/js/core/version.js','utf8').match(/APP_VERSION\\s*=\\s*'(v[\\d.]+)'/)[1];const s=fs.readFileSync('public/sw.js','utf8').match(/nihongo-(v[\\d.]+)/)[1];console.log(v===s?'✅ '+v:'❌ MISMATCH '+v+' vs '+s);if(v!==s)process.exit(1)\"",
    "deploy": "wrangler pages deploy public",
    "preview": "wrangler pages dev public"
  },
  "devDependencies": {
    "wrangler": "^4.81.0"
  }
}
