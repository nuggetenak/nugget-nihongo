{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@public/*": ["public/*"],
      "@data/*": ["public/data/*"],
      "@js/*": ["public/js/*"]
    },
    "checkJs": false,
    "target": "ES2020",
    "module": "ES2020"
  },
  "include": ["public/**/*.js", "tests/**/*.js", "tools/**/*.js"],
  "exclude": ["node_modules"]
}
